# Configuration File
DANGEROUSLY_DISABLE_HOST_CHECK=true
HOST=0.0.0.0
PORT=3099

# CloudFormation Template Paths (relative to project root directory)
CF_TEMPLATE_PATH=cli-min/1-main-stack-eks-control.yaml
HYPERPOD_TEMPLATE_PATH=cli-min/2-hypd-compute.yaml
REACT_APP_DEMO_EKSNG=false
REACT_APP_SHOW_SCRIPT_RECIPE=false
REACT_APP_SHOW_DEPRECATED_CREATE_CLUSTER=false

# Refresh Mechanism Configuration
# Set to true to disable old GlobalRefreshManager and use new resourceEventBus
REACT_APP_DISABLE_GLOBAL_REFRESH=true

# Application Version
REACT_APP_VERSION=main